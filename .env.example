# ============================================================================
# AI Clip Farm - Environment Configuration
# Copy this file to `.env` and fill in the values.
#
# Every variable here maps 1:1 to a field in app/core/config.py (Settings) —
# that file is the single source of truth for defaults and validation. A
# typo'd value for an enum-like field (e.g. WHISPER_DEVICE=gpu instead of
# cuda) fails fast at process startup with a clear error instead of an
# obscure crash hours into a batch run.
# ============================================================================

# --- Runtime environment ------------------------------------------------
# development | staging | production
# In production, ANTHROPIC_API_KEY and API_KEY are REQUIRED (the app refuses
# to start without them) and CORS_ORIGINS must not be "*".
ENVIRONMENT=development

# --- Claude API (required) ---------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Model used for transcript analysis + metadata generation.
CLAUDE_MODEL=claude-opus-4-8
# Effort: low | medium | high | xhigh | max
CLAUDE_EFFORT=high
CLAUDE_TIMEOUT_SECONDS=120
CLAUDE_MAX_RETRIES=5

# --- Whisper (local transcription) ------------------------------------------
WHISPER_BACKEND=faster_whisper
# Model size: tiny | base | small | medium | large-v3
WHISPER_MODEL=large-v3
# cpu | cuda | auto  (auto probes for a usable CUDA device and falls back to
# cpu automatically — safe default across mixed GPU/CPU worker fleets)
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=int8
WHISPER_CACHE_MODELS=true

# --- Clip selection ----------------------------------------------------------
MIN_CLIPS_PER_VIDEO=10
MAX_CLIPS_PER_VIDEO=15
MIN_CLIP_SECONDS=15
MAX_CLIP_SECONDS=90

# --- Rendering ---------------------------------------------------------------
TARGET_WIDTH=1080
TARGET_HEIGHT=1920
TARGET_FPS=30
# Speaker tracking backend: mediapipe | opencv | center (no tracking)
TRACKING_BACKEND=mediapipe
# Detect a face every Nth frame and interpolate between hits — the main
# reframe.py speed lever. 1 = detect every frame (slowest, marginally
# smoother); 3-5 is a good speed/quality balance.
FACE_DETECT_STRIDE=3
SUBTITLE_STYLE=karaoke_bold
# auto | none | nvenc | vaapi | qsv — auto probes for an NVIDIA GPU (nvidia-smi)
# and uses NVENC if present, falling back to libx264 automatically (including
# a runtime fallback if the hardware encoder fails mid-job).
FFMPEG_HWACCEL=auto
FFMPEG_PRESET=veryfast
FFMPEG_CRF=20
FFMPEG_TIMEOUT_SECONDS=1800

# --- Storage / retention ------------------------------------------------------
DATA_DIR=/data
INPUT_DIR=/data/input
WORK_DIR=/data/work
OUTPUT_DIR=/data/output
# Delete each video's working directory once all its clips finish rendering.
# Without this, /data/work grows unbounded under daily unattended operation.
CLEANUP_WORK_DIR_ON_SUCCESS=true
KEEP_WORK_DIR_ON_FAILURE=true
# Safety-net Celery Beat task (runs hourly) purges anything older than this,
# regardless of the flags above — covers crashes/kill -9 that skip normal cleanup.
WORK_DIR_RETENTION_HOURS=48
MAX_UPLOAD_SIZE_MB=2048
MAX_DOWNLOAD_SIZE_MB=4096

# --- Database ----------------------------------------------------------------
POSTGRES_USER=clipfarm
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=clipfarm
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://clipfarm:change-me-in-production@postgres:5432/clipfarm
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# --- Redis / Celery ----------------------------------------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
# How many clips to render in parallel per worker process.
RENDER_CONCURRENCY=2
# Soft limit lets a task clean up (SIGTERM) before the hard limit kills it
# (SIGKILL). Raise both for very long source videos (2h+ podcasts).
CELERY_TASK_SOFT_TIME_LIMIT=7200
CELERY_TASK_TIME_LIMIT=10800

# --- API -----------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000
LOG_LEVEL=INFO
# false = human-readable console logs (dev); true = one JSON object per line
# (production — feed to Loki/ELK/CloudWatch).
LOG_JSON=false
# Comma-separated list of allowed browser origins for the web UI/API.
# Must NOT be "*" in production.
CORS_ORIGINS=http://localhost:8000
DOCS_ENABLED=true
# Which host interface Docker publishes ports on. 0.0.0.0 = reachable from
# the network (dev default); set to 127.0.0.1 in production so only nginx
# (which proxies from the public interface with TLS) is externally reachable.
BIND_ADDR=0.0.0.0

# --- Security ------------------------------------------------------------
# Every /api/* request must send `X-API-Key: <value>` once this is set.
# Leave empty for frictionless local development. REQUIRED in production —
# generate one with:
#   python -c "from app.core.config import generate_api_key; print(generate_api_key())"
API_KEY=
RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_UPLOAD_PER_HOUR=20
ALLOWED_VIDEO_EXTENSIONS=.mp4,.mov,.mkv,.webm
# Hosts yt-dlp is allowed to fetch from — an SSRF guard. Extend only with
# hosts you trust yt-dlp's extractor for.
ALLOWED_SOURCE_HOSTS=youtube.com,www.youtube.com,youtu.be,m.youtube.com,music.youtube.com

# --- Observability ---------------------------------------------------------
METRICS_ENABLED=true
SENTRY_DSN=
# Optional: post a message when a video/clip fails or the daily failure
# report task runs. Leave empty to disable.
SLACK_WEBHOOK_URL=

# --- Flower (Celery monitor) — required, no default, must not be left blank
FLOWER_USER=admin
FLOWER_PASSWORD=change-me

# --- n8n ---------------------------------------------------------------------
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me
N8N_ENCRYPTION_KEY=generate-a-random-32-char-string
